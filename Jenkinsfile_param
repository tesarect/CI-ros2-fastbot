pipeline {
  agent any

  parameters {
    choice(
      name: 'TEST_MODE',
      choices: ['PASS', 'FAIL'],
      description: 'PASS: runs test_waypoints (targets 1.0,1.0 with 0.1 tolerance). FAIL: runs test_fail_waypoints (same targets but 0.01 tolerance — robot cannot meet this).'
    )
  }

  environment {
    DOCKER_IMAGE = 'fastbot-humble-gazebo'
    GAZEBO_STARTUP_TIMEOUT = '90'
  }

  stages {
    stage('Compute Tag') {
      steps {
        script {
          env.IMAGE_TAG = (env.GIT_COMMIT ? env.GIT_COMMIT.take(7) : 'local')
          env.TEST_BINARY = (params.TEST_MODE == 'FAIL') ? 'test_fail_waypoints' : 'test_waypoints'
        }
        echo "Using image tag: ${IMAGE_TAG}"
        echo "Test mode: ${params.TEST_MODE} — running binary: ${TEST_BINARY}"
      }
    }

    stage('Build Docker Image') {
      steps {
        echo "Building Docker image: ${DOCKER_IMAGE}:${IMAGE_TAG}"
        sh "docker build -t ${DOCKER_IMAGE}:${IMAGE_TAG} ."
      }
    }

    stage('Run Tests') {
      steps {
        echo " 🟢 Running tests in: ${DOCKER_IMAGE}:${IMAGE_TAG}"
        sh '''
          xhost +local:docker || true
          docker run --rm \
            -e DISPLAY=${DISPLAY} \
            -v /tmp/.X11-unix:/tmp/.X11-unix:rw \
            -e GAZEBO_STARTUP_TIMEOUT=${GAZEBO_STARTUP_TIMEOUT} \
            -e TEST_BINARY=${TEST_BINARY} \
            ${DOCKER_IMAGE}:${IMAGE_TAG} bash -lc '
              set -e
              source /opt/ros/humble/setup.bash
              source /ros2_ws/install/setup.bash

              export ROS_LOG_DIR=/tmp/roslog
              mkdir -p "$ROS_LOG_DIR"

              echo "Launching Gazebo..."
              ros2 launch fastbot_gazebo one_fastbot_room.launch.py >/tmp/gazebo.log 2>&1 &

              ODOM_TOPIC="/fastbot/odom"
              echo "Waiting for ${ODOM_TOPIC} (timeout: ${GAZEBO_STARTUP_TIMEOUT}s)..."
              timeout "${GAZEBO_STARTUP_TIMEOUT}" bash -c "
                until ros2 topic list 2>/dev/null | grep -q \"^${ODOM_TOPIC}\$\"; do
                  sleep 1
                done
              " || { echo "ERROR: Timeout waiting for ${ODOM_TOPIC}"; cat /tmp/gazebo.log || true; exit 1; }
              echo "Simulation ready."

              echo "Starting Waypoints Action Server..."
              ros2 run fastbot_waypoints fastbot_action_server >/tmp/action_server.log 2>&1 &

              ACTION_NAME="/fastbot_as"
              echo "Waiting for action server (${ACTION_NAME})..."
              timeout 15 bash -c "
                until ros2 action list 2>/dev/null | grep -q \"^${ACTION_NAME}\$\"; do
                  sleep 1
                done
              " || { echo "ERROR: Timeout waiting for action server ${ACTION_NAME}"; cat /tmp/action_server.log || true; exit 1; }
              echo "Action server ready."

              echo "Running: ${TEST_BINARY}..."
              mkdir -p /ros2_ws/build/fastbot_waypoints/test_results/fastbot_waypoints
              timeout 300 /ros2_ws/build/fastbot_waypoints/${TEST_BINARY} \
                --gtest_output=xml:/ros2_ws/build/fastbot_waypoints/test_results/fastbot_waypoints/${TEST_BINARY}.gtest.xml
              echo "Tests done."
            '
        '''
      }
    }
  }

  post {
    always {
      sh 'docker image prune -f >/dev/null 2>&1 || true'
    }
    success { echo 'Pipeline completed successfully!' }
    failure  { echo 'Pipeline failed!' }
  }
}